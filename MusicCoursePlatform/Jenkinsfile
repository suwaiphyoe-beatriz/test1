pipeline {
    agent any

    tools {
        maven 'Maven3'
        jdk 'JDK21'
    }

    environment {
        DOCKER_IMAGE = 'music-course-platform'
        DOCKER_TAG = 'latest'
        DB_NAME = 'music_lesson_db'
        DB_USER = 'root'
        DB_PASSWORD = 'swp123'
        DB_PORT = '3307'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Start MySQL Container') {
            steps {
                sh """
                    docker run -d \
                    --name test-mysql \
                    -e MYSQL_ROOT_PASSWORD=${DB_PASSWORD} \
                    -e MYSQL_DATABASE=${DB_NAME} \
                    -p ${DB_PORT}:3306 \
                    mysql:8.0
                """
            }
        }

        stage('Wait for Database') {
            steps {
                sh 'sleep 20'
            }
        }

        stage('Setup Database') {
            steps {
                dir('MusicCoursePlatform') {
                    sh """
                        docker exec -i test-mysql \
                        mysql -u root -p${DB_PASSWORD} ${DB_NAME} < database/schema.sql
                    """
                }
            }
        }

        stage('Build') {
            steps {
                dir('MusicCoursePlatform') {
                    sh 'mvn clean compile'
                }
            }
        }

        stage('Test') {
            steps {
                dir('MusicCoursePlatform') {
                    sh 'mvn test'
                }
            }
            post {
                always {
                    junit 'MusicCoursePlatform/target/surefire-reports/*.xml'
                }
            }
        }

        stage('Package') {
            steps {
                dir('MusicCoursePlatform') {
                    sh 'mvn package -DskipTests'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('MusicCoursePlatform') {
                    sh "docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} ."
                }
            }
        }
    }

    post {
        always {
            sh 'docker stop test-mysql || true'
            sh 'docker rm test-mysql || true'
        }

        success {
            echo 'Pipeline completed successfully!'
        }

        failure {
            echo 'Pipeline failed!'
        }
    }
}
