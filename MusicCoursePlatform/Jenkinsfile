pipeline {
    agent any

    tools {
        maven 'Maven3'
        jdk 'JDK21'
    }

    environment {
        DOCKER_IMAGE = 'music-course-platform'
        DOCKER_TAG = 'latest'
        DB_NAME = 'music_lesson_db'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Setup Database') {
            steps {
                dir('MusicCoursePlatform') {
                    withCredentials([string(credentialsId: 'DB_PASSWORD', variable: 'DB_PASSWORD')]) {
                        sh """
                            mysql -u root -p$DB_PASSWORD -e "
                            CREATE DATABASE IF NOT EXISTS ${DB_NAME};
                            "
                            mysql -u root -p$DB_PASSWORD ${DB_NAME} < database/schema.sql
                        """
                    }
                }
            }
        }

        stage('Build') {
            steps {
                dir('MusicCoursePlatform') {
                    sh 'mvn clean compile'
                }
            }
        }

        stage('Test') {
            steps {
                dir('MusicCoursePlatform') {
                    sh 'mvn test'
                }
            }
            post {
                always {
                    junit 'MusicCoursePlatform/target/surefire-reports/*.xml'
                }
            }
        }

        stage('Code Coverage') {
            steps {
                dir('MusicCoursePlatform') {
                    sh 'mvn jacoco:report'
                }
            }
            post {
                always {
                    jacoco(
                        execPattern: 'MusicCoursePlatform/target/jacoco.exec',
                        classPattern: 'MusicCoursePlatform/target/classes',
                        sourcePattern: 'MusicCoursePlatform/src/main/java'
                    )
                }
            }
        }

        stage('Package') {
            steps {
                dir('MusicCoursePlatform') {
                    sh 'mvn package -DskipTests'
                }
            }
        }

        stage('Archive Artifact') {
            steps {
                archiveArtifacts artifacts: 'MusicCoursePlatform/target/*.jar', fingerprint: true
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('MusicCoursePlatform') {
                    sh "docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} ."
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully!'
        }
        failure {
            echo 'Pipeline failed!'
        }
    }
}
